# ---- Cloud Fashion Backend ENV ----
APP_ENV=development
APP_URL=http://localhost/CloudFashion/backend
FRONTEND_URL=http://localhost:5173

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=cloudfashion
DB_USER=root
DB_PASS=

# JWT
JWT_SECRET=change-this-to-a-long-random-string
JWT_TTL=86400

# Mail (SMTP). For local dev leave MAIL_DRIVER=log to write OTPs to storage/mail.log
MAIL_DRIVER=log
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=no-reply@cloudfashion.com
MAIL_FROM_NAME=Cloud Fashion

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
