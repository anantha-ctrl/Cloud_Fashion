<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /CloudFashion/backend/

    # Forward the Authorization header to PHP (CGI/FastCGI strip it otherwise)
    RewriteCond %{HTTP:Authorization} ^(.+)$
    RewriteRule ^ - [E=HTTP_AUTHORIZATION:%1]

    # Route everything that isn't a real file/dir to the front controller
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ index.php [QSA,L]
</IfModule>

# Fallback for mod_php setups
SetEnvIf Authorization "(.*)" HTTP_AUTHORIZATION=$1
